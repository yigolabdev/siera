rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // 헬퍼 함수
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isApproved == true;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'choi@yigolab.com';
    }
    
    function isAdmin() {
      return isSuperAdmin() || (
             isAuthenticated() && 
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'chairman' || 
              get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'vice_chairman' ||
              get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'secretary' ||
              get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'committee'));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // 크로스 프로바이더 계정 병합: 이전 계정이 현재 사용자로 병합되었는지 확인
    function isMergedIntoCurrentUser(refId) {
      return refId != null &&
             isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(refId)) &&
             get(/databases/$(database)/documents/members/$(refId)).data.mergedInto == request.auth.uid;
    }
    
    // ========================================
    // 회원 (members) 컬렉션
    // ========================================
    match /members/{memberId} {
      // 읽기: 모든 사용자 (간편 신청 페이지에서 이름 검색용)
      allow read: if true;
      
      // 생성: 본인 UID 또는 관리자
      allow create: if (isAuthenticated() && request.auth.uid == memberId) || isAdmin();
      
      // 수정: 본인, 관리자, 또는 크로스 프로바이더 계정 병합 (제한된 필드만)
      allow update: if isOwner(memberId) || isAdmin() ||
                       (isAuthenticated() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['isActive', 'mergedInto', 'mergedAt', 'updatedAt']) &&
                        request.resource.data.isActive == false &&
                        request.resource.data.mergedInto == request.auth.uid);
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 산행 (events) 컬렉션
    // ========================================
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 참석자 (participants) 컬렉션 - 레거시
    // ========================================
    match /participants/{participantId} {
      allow read: if isAuthenticated() && isApproved();
      allow create: if isAuthenticated() && isApproved() &&
                      request.auth.uid == request.resource.data.memberId;
      allow update: if isOwner(resource.data.memberId) || isAdmin();
      allow delete: if isOwner(resource.data.memberId) || isAdmin();
    }
    
    // ========================================
    // 조 편성 (teams) 컬렉션
    // ========================================
    match /teams/{teamId} {
      // 읽기: 모든 사용자 (간편 취소 시 조편성 확인 필요)
      allow read: if true;
      
      // 생성, 삭제: 관리자만
      allow create, delete: if isAdmin();
      
      // 수정: 관리자 또는 간편 취소 시 조원 목록(members)만 수정 허용
      allow update: if isAdmin() ||
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['members', 'updatedAt']);
    }
    
    // ========================================
    // 공지사항 (notices) 컬렉션
    // ========================================
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 게시판 (posts) 컬렉션
    // ========================================
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.auth.uid == request.resource.data.authorId;
      allow update: if isOwner(resource.data.authorId) || isAdmin() ||
                      (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['views', 'comments', 'likes', 'likedBy', 'updatedAt']));
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
    
    // ========================================
    // 댓글 (comments) 컬렉션
    // ========================================
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if request.auth != null && 
                      request.auth.uid == request.resource.data.authorId;
      allow update: if isOwner(resource.data.authorId) || isAdmin() ||
                      (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likes', 'likedBy', 'updatedAt']));
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
    
    // ========================================
    // 사연 (poems) 컬렉션
    // ========================================
    match /poems/{poemId} {
      allow read: if isAuthenticated() && isApproved();
      allow create: if isAuthenticated() && isApproved() &&
                      request.auth.uid == request.resource.data.authorId;
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
    
    // ========================================
    // 이달의 시 (monthlyPoems) 컬렉션
    // ========================================
    match /monthlyPoems/{poemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 갤러리/사진 (photos) 컬렉션
    // ========================================
    match /photos/{photoId} {
      allow read: if isAuthenticated() && isApproved();
      allow create: if isAuthenticated() && isApproved() &&
                      request.auth.uid == request.resource.data.uploadedBy;
      allow update: if isAuthenticated() && (isOwner(resource.data.uploadedBy) || isAdmin());
      allow delete: if isAuthenticated() && (isOwner(resource.data.uploadedBy) || isAdmin());
    }
    
    // ========================================
    // 운영진 (executives) 컬렉션
    // ========================================
    match /executives/{executiveId} {
      allow read: if isAuthenticated() && isApproved();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isMergedIntoCurrentUser(resource.data.memberId);
    }
    
    // ========================================
    // 연혁 (clubHistory) 컬렉션
    // ========================================
    match /clubHistory/{historyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 회칙 (rules) 컬렉션
    // ========================================
    match /rules/{ruleId} {
      allow read: if isAuthenticated() && isApproved();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 대기 회원 (pendingUsers) 컬렉션
    // ========================================
    match /pendingUsers/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update, delete: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
    }
    
    // ========================================
    // 산행 이력 (hikingHistory) 컬렉션
    // ========================================
    match /hikingHistory/{hikeId} {
      allow read: if isAuthenticated() && isApproved();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
                       isMergedIntoCurrentUser(resource.data.memberId) ||
                       isMergedIntoCurrentUser(resource.data.userId);
    }
    
    // ========================================
    // 산행 후기 댓글 (hikingComments) 컬렉션
    // ========================================
    match /hikingComments/{commentId} {
      allow read: if isAuthenticated() && isApproved();
      allow create: if isAuthenticated() && isApproved() &&
                      request.auth.uid == request.resource.data.authorId;
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
    
    // ========================================
    // 참가 신청 (participations) 컬렉션
    // NOTE: 간편 신청/취소 페이지가 비인증으로 동작하므로
    //       read/create/delete를 공개 허용
    // ========================================
    match /participations/{participationId} {
      allow read: if true;
      // 간편 신청: 비인증 허용하되, 필수 필드 및 데이터 검증
      allow create: if true
                       && request.resource.data.keys().hasAll(['eventId', 'userName'])
                       && request.resource.data.eventId is string
                       && request.resource.data.userName is string
                       && request.resource.data.userName.size() > 0
                       && request.resource.data.userName.size() < 50;
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId) ||
                       isMergedIntoCurrentUser(resource.data.userId);
      // 간편 취소를 위해 비인증 삭제 유지
      allow delete: if true;
    }
    
    // ========================================
    // 결제 (payments) 컬렉션
    // NOTE: 간편 취소 시 관련 결제 정보 조회/삭제 필요
    // ========================================
    match /payments/{paymentId} {
      allow read: if true;    // 간편 취소 시 결제 조회 필요
      // 결제 생성: 인증 필수 + 필수 필드 검증
      allow create: if isAuthenticated()
                       && request.resource.data.keys().hasAll(['eventId', 'userId'])
                       && request.resource.data.eventId is string
                       && request.resource.data.userId is string;
      allow update: if isAdmin() ||
                       isMergedIntoCurrentUser(resource.data.userId) ||
                       isMergedIntoCurrentUser(resource.data.memberId);
      allow delete: if true;  // 간편 취소 시 결제 삭제 필요
    }
    
    // ========================================
    // 출석 (attendances) 컬렉션
    // ========================================
    match /attendances/{attendanceId} {
      allow read: if isAuthenticated() && isApproved();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isMergedIntoCurrentUser(resource.data.memberId);
    }
    
    // ========================================
    // 비회원 게스트 신청 (guestApplications) 컬렉션
    // ========================================
    match /guestApplications/{applicationId} {
      allow read: if isAdmin();
      // 게스트 신청: 비인증 허용하되, 필수 필드 및 데이터 검증
      allow create: if true
                       && request.resource.data.keys().hasAll(['name', 'phoneNumber', 'eventId'])
                       && request.resource.data.name is string
                       && request.resource.data.name.size() > 0
                       && request.resource.data.name.size() < 50
                       && request.resource.data.phoneNumber is string
                       && request.resource.data.eventId is string;
      allow update, delete: if isAdmin();
    }
    
    // ========================================
    // 연회비 (annualFees) 컬렉션
    // ========================================
    match /annualFees/{feeId} {
      allow read: if isAuthenticated() && isApproved();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 사전등록 회원 (preRegisteredMembers) 컬렉션
    // ========================================
    match /preRegisteredMembers/{memberId} {
      // 회원가입 시 사전등록 확인 필요 → 인증된 사용자만
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================
    // 자료실 (sharedFiles) 컬렉션
    // ========================================
    match /sharedFiles/{fileId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // 기본 거부
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
